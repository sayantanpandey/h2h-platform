{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "develop": true,
      "dev/backend": true,
      "dev/frontend": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/appointment-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/expire-pending-payments",
      "schedule": "*/10 * * * *"
    }
  ]
}
