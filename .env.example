# ===========================================
# H2H HEALTHCARE - ENVIRONMENT VARIABLES
# ===========================================
# Set these in Vercel: Project → Settings → Environment Variables
# Or copy to .env.local for local development
# See docs/SETUP_GUIDE.md for how to obtain each key

# APP
# Local dev: use http://localhost:3000 (or leave unset — auth callbacks use the request host)
# Production (Vercel): https://beta.healtohealth.in
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=H2H Healthcare

# SUPER ADMIN (first-time setup)
SUPER_ADMIN_SECRET_KEY=

# SUPABASE (required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# RAZORPAY (required for booking payments)
# Dashboard → Settings → API Keys (Test mode for localhost)
# KEY_ID and NEXT_PUBLIC_RAZORPAY_KEY_ID must be the SAME value (rzp_test_...)
# IMPORTANT: If you use .env.local, update Razorpay keys THERE too — it overrides .env
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Webhook secret is NOT the API secret — create under Settings → Webhooks → your endpoint secret
# Local test: ngrok http 3000 → URL https://YOUR.ngrok-free.app/api/payments/webhook
# Events: payment.captured, payment.failed
RAZORPAY_WEBHOOK_SECRET=

# TWILIO (WhatsApp/SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
TWILIO_SMS_NUMBER=

# EMAIL
RESEND_API_KEY=
EMAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# GOOGLE (OAuth, Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# TAWK.TO (Live Chat)
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=

# POSTHOG (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# MAPBOX (Maps)
NEXT_PUBLIC_MAPBOX_TOKEN=

# CLOUDINARY (optional)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# UPSTASH REDIS (optional, rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# DAILY.CO (Video Consultations)
DAILY_API_KEY=

# CRON (for Vercel Cron - set in Vercel)
CRON_SECRET=